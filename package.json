{
  "name": "@kaonashi-dev/techne",
  "version": "0.4.0",
  "description": "Techne — a Bun-native application framework built on Elysia with a decorator-first developer experience",
  "module": "src/index.ts",
  "main": "src/index.ts",
  "types": "dist/types/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./src/index.ts",
      "types": "./dist/types/index.d.ts"
    },
    "./common": {
      "bun": "./src/common/index.ts",
      "import": "./src/common/index.ts",
      "types": "./dist/types/common/index.d.ts"
    },
    "./core": {
      "bun": "./src/core/index.ts",
      "import": "./src/core/index.ts",
      "types": "./dist/types/core/index.d.ts"
    },
    "./config": {
      "bun": "./src/config/index.ts",
      "import": "./src/config/index.ts",
      "types": "./dist/types/config/index.d.ts"
    },
    "./jwt": {
      "bun": "./src/jwt/index.ts",
      "import": "./src/jwt/index.ts",
      "types": "./dist/types/jwt/index.d.ts"
    },
    "./swagger": {
      "bun": "./src/swagger/index.ts",
      "import": "./src/swagger/index.ts",
      "types": "./dist/types/swagger/index.d.ts"
    },
    "./health": {
      "bun": "./src/health/index.ts",
      "import": "./src/health/index.ts",
      "types": "./dist/types/health/index.d.ts"
    },
    "./testing": {
      "bun": "./src/testing/index.ts",
      "import": "./src/testing/index.ts",
      "types": "./dist/types/testing/index.d.ts"
    },
    "./cqrs": {
      "bun": "./src/cqrs/index.ts",
      "import": "./src/cqrs/index.ts",
      "types": "./dist/types/cqrs/index.d.ts"
    },
    "./queue": {
      "bun": "./src/queue/index.ts",
      "import": "./src/queue/index.ts",
      "types": "./dist/types/queue/index.d.ts"
    },
    "./mq": {
      "bun": "./src/mq/index.ts",
      "import": "./src/mq/index.ts",
      "types": "./dist/types/mq/index.d.ts"
    },
    "./contract": {
      "bun": "./src/contract/index.ts",
      "import": "./src/contract/index.ts",
      "types": "./dist/types/contract/index.d.ts"
    }
  },
  "bin": {
    "techne": "src/cli/index.ts"
  },
  "files": [
    "src",
    "dist/types",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "bun test tests/*.test.ts",
    "test:watch": "bun test --watch tests/*.test.ts",
    "test:nestjs": "bun test tests/nestjs/",
    "check": "bun run lint && bun run format:check",
    "check:fix": "bun run lint:fix && bun run format .",
    "bench": "bun run benchmarks/http.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "elysia": "^1.4.28"
  }
}
